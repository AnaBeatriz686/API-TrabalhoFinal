              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", () => {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Retorna token\", () => {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.token).to.exist;\r",
                  "    pm.environment.set(\"token\", json.token);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Retorna usuário\", () => {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.usuario.email).to.eql(\"anabeatriztestes@email.com\");\r",
